---
import DemoButton from "../Others/DemoButton.astro";

interface Props {
  imgSrc: string;
  alt: string;
  titulo: string;
  descripcion: string;
  demo: string;
  repositorio: string;
  tecnologias: string[];
}

const { imgSrc, titulo, descripcion, demo, repositorio, tecnologias, alt } =
  Astro.props;
---

<div>
  <div class="myCard">
    <div class="innerCard">
      <div class="frontSide">
        <img src={imgSrc} alt={alt}/>
        <p class="text-2xl">{titulo}</p>
        <div class="w-full flex justify-evenly">
          {tecnologias.map((tecnologia) => <i class={tecnologia} />)}
        </div>
      </div>

      <div class="backSide">
        <p>{descripcion}</p>
        <div>
          <a href={demo}><DemoButton/></a>
          <a href={repositorio}>Repositorio</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .myCard {
  background-color: transparent;
  width: 254px;
  height: 340px;
  perspective: 1000px;
  margin-bottom: 12px;
}

.title {
  font-size: 1.5em;
  font-weight: 900;
  text-align: center;
  margin: 0;
}

.innerCard {
  position: relative;
  width: 100%;
  height: 100%;
  text-align: center;
  transition: transform 0.8s;
  transform-style: preserve-3d;
  cursor: pointer;
}

.myCard:hover .innerCard {
  transform: rotateY(180deg);
}

.frontSide,
.backSide {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-evenly;
  width: 100%;
  height: 100%;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  border-radius: 1rem;
  color: white;
  font-weight: 700;
}

.frontSide,
.frontSide::before {
    background: linear-gradient(43deg, rgba(19, 21, 26, 1) 0%, rgba(65, 88, 208, 1) 46%, rgba(0, 255, 255, 1) 46%, rgba(200, 80, 192, 1) 100%, rgba(255, 255, 255, 1) 100%);
}

.backSide,
.backSide::before {
  background-image: linear-gradient(160deg, #0093E9 0%, #80D0C7 100%);
}

.backSide {
  transform: rotateY(180deg);
}
</style>
