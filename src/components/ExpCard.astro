---
import DemoButton from "./DemoButton.astro";

interface Props {
    imgSrc: string;
    titulo : string;
    descripcion : string;
    demo: string;
    repositorio : string;
}

const {imgSrc, titulo, descripcion, demo, repositorio} = Astro.props;

---

<div class="text-center w-1/3 mx-8">
    <img src={imgSrc}/>
    <p class="text-2xl">{titulo}</p>
    <p>{descripcion}</p>
    <div>
        <a href={demo}><DemoButton texto="Ver demo"/></a>
        <a href={repositorio}>Repositorio</a>
    </div>
</div>