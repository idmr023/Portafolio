---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Menu from '../components/Menu.astro';
import DemoButton from '../components/DemoButton.astro';
import SocialMediaBar from '../components/SocialMediaBar.astro';
import Card from '../components/Card.astro';
import ExpCard from '../components/ExpCard.astro';

const conocimientos = [
	{
		nombre: "HTML5",
		path: "fa-brands fa-html5"
	},
	{
		nombre: "CSS3",
		path: "fa-brands fa-css3"
	},
	{
		nombre: "JS",
		path: "fa-brands fa-js"
	},
	{
		nombre:"GitHub",
		path:"fa-brands fa-github",
				
	},
	{
		nombre:"Git",
		path:"fa-brands fa-git",
				
	},
	{
		nombre:"SQL",
		path:"fa-regular fa-file-code"
				
	},
	{
		nombre: "MySQL",
		path: "fa-solid fa-database"
	},
	{
		nombre: "JAVA",
		path: "fa-brands fa-java"
	},
	{
		nombre: "Microsfot Excell",
		path: "fa-solid fa-file-excel"
	},
	{
		nombre: "React",
		path: "fa-brands fa-react"
	},
	{
		nombre: "JS",
		path: "fa-brands fa-php"
	},
]

---

<Layout title="Portafolio - Inicio">
	<Menu />
	<div class="flex w-4/5 mt-12 mb-3 mx-auto">
		<img class="w-44 mr-7 rounded-md" src="../../assets/img/profile.png" alt="Imagen de perfil">
		<div>
			<h1 class="text-4xl text-cyan-600">Ivan Daniel Manrique Roa</h1>
			<p class="text-white">Desarrollador Full Stack</p>
			<div class="flex w-1/2 justify-between mt-5">
				<SocialMediaBar/>
			</div>
		</div>
		
	</div>
	
	<section class="flex w-4/5 mx-auto justify-between">
		<div>
			<h1 class="text-4xl text-cyan-600">Sobre mi</h1>
			<p class="text-white">Estudio Ingeniería de Software, me encuentro en el 7mo ciclo.<br/>Amante de los libros ditópicos, el aprendizaje continuo y la tecnología</p>
		</div>
		
		<div>
			<h1 class="text-4xl text-cyan-600">Conocimientos</h1>
			<div class="flex flex-wrap text-white">
				{
					conocimientos.map((conocimiento, index) => (
						<Card
							path={conocimiento.path}
							nombre={conocimiento.nombre}
							/>
							))
						}
			</div>
		</div>
		
	</section>

	<section class="w-4/5 mt-12 mx-auto justify-between text-white">
		<h1 class="text-4xl p-2 text-cyan-600">Formación académica</h1>
		<div class="flex justify-between p-6">
			<div class="text-center w-28">
				<img src="https://utp-sistemas.com/asset/img/logo-utp.png" class="mb-4" />
				<h2 class="text-white">Ingeniería de Software - UTP</h2>
				<p>En curso</p>
			</div>
			
			<div class="text-center w-28">
				<img src="https://logos-world.net/wp-content/uploads/2021/11/Udemy-Logo.png" class="mb-4"/>
				<h2 class="text-white">Máster Completo en Java de cero a experto 2023 - Udemy</h2>
				<p>En curso</p>
			</div>
			
			<div class="text-center w-28">
				<img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQJ1lU2P15cEy8AJbOaIArEPdNEGc9-y_6pV6vt1gKGDc0zMFgzGdDpLFv42Sdch85QybY&usqp=CAU" class="mb-4"/>
				<h2 class="text-white">Especialización FrontEnd - Alura</h2>
				<p>Finalizado</p>
			</div>
			
		</div>	
	</section>
	
	<section class="w-4/5 mx-auto justify-between text-white">
		<h1 class="text-4xl p-2 text-cyan-600">Experiencia profesional</h1>
		<div class="flex justify-between p-6">
			
			<ExpCard 
			imgSrc="https://raw.githubusercontent.com/idmr023/ProyectoWeb/main/images/image.png"
			titulo="Hotel Antares"
			descripcion="Proyecto de la universidad, implementa JAVA avanzado. Herencia, JSP, JFS, conexión a MySQL. Este proyecto fue hecho para la empresa ficicia Hotel Antares, en la misma el usuario puede consultar los clientes, así como editarlos o eliminarlos, lo mismo sucede con las habitaciones. Para poder entrar a cualquier página el usuario debe estar autenticado. Se envía un correo al correo del admin cada vez que inicia sesión."
			demo="#"
			repositorio="https://github.com/idmr023/ProyectoWeb"
			/>
			
			<ExpCard 
			imgSrc="https://portafolio-idmr023.vercel.app/assets/proy_BancoChanchitoUTP.png"
			titulo="Banco Chanchito UTP"
			descripcion="Proyecto de la universidad, implementa HTML 5, CSS3, PHP y MySQL. Trata acerca de una página de un banco fictio, donde el cliente puede regsitrarse, iniciar y cerrar sesión. Además, puede crear su tarjeta, su seguro y consultar su estado de cuenta. Toda la página es responsiva."
			demo="#"
			repositorio="https://github.com/idmr023/ChanchitoUTP"
			/>

			<ExpCard 
				imgSrc="../../assets/img/proyLibreria.png"
				titulo="Proyecto Libreria"
				descripcion="Proyecto personal en el que use REACT, TailWind, Axios, MySQL. Este proyecto lo cree con la intención de juntar todos mis conocimientos en un solo proyecto. El proyecto presenta rutas protegidas, autenticación y registro del usuario, listado de libros desde la base de datos y envía correo de contacto a tráves del formulario de contacto. Además, usando Stack AI y Botpress cree un ChatBot personalizado para atender las consultas de los clientes."
				demo="https://libreria-two.vercel.app"
				repositorio="https://github.com/idmr023/Libreria"
			/>
		</div>
	</section>

	<Footer/>

</Layout>